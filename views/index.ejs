<!DOCTYPE html>
<html>
<head>
    <title>Gold Market Africa</title>

    <link rel="stylesheet" href="/css/style.css">

    <style>

        .hero {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 40px;
        }

        .hero-content {
            max-width: 800px;
        }

        .hero h1 {
            font-size: 60px;
            margin-bottom: 15px;
            color: #C8A24A;
            letter-spacing: 2px;
        }

        .hero p {
            font-size: 18px;
            color: #AAB3C5;
            line-height: 1.8;
            margin-bottom: 30px;
        }

        .section-title {
            text-align: center;
            color: #C8A24A;
            font-size: 34px;
            margin-bottom: 10px;
        }

        .section-subtitle {
            text-align: center;
            color: #AAB3C5;
            margin-bottom: 40px;
        }

        .about {
            max-width: 1000px;
            margin: auto;
            text-align: center;
            padding: 80px 30px;
        }

        .about p {
            color: #AAB3C5;
            line-height: 1.9;
            font-size: 17px;
        }

        .why-us {
            padding: 60px 40px;
        }

        .insights {
            padding: 60px 40px;
        }

        .insight-card {
            background: #101C33;
            border: 1px solid rgba(255,255,255,0.06);
            padding: 20px;
            border-radius: 10px;
        }

        .insight-card h3 {
            color: #C8A24A;
        }

        .footer-content {
            max-width: 1200px;
            margin: auto;
        }

    </style>

</head>
<body>

<header>

    <h2>Gold Market Africa</h2>

    <nav>
    <a href="/">Home</a>
    <a href="/shop">Collection</a>
    <a href="/about">About</a>
    <a href="/blog">Insights</a>
    <a href="/contact">Contact</a>
</nav>

</header>

<!-- HERO -->

<section class="hero">

    <div class="hero-content">

        <h1 class="glow">
            <span id="typed-text"></span>
            <span class="cursor">|</span>
        </h1>

        <p>
            Discover premium gold products, precious metal collections,
            and luxury assets presented with excellence and authenticity.
        </p>

        <a href="/shop" class="btn">
            Explore Collection
        </a>

    </div>

    <div class="scroll-indicator">
        <div class="mouse"></div>
        <p>Scroll Down</p>
    </div>

</section>

<section class="market-banner fade-section">

    <h2>Gold Market Intelligence</h2>

    <p>
        Daily insights, investment guides, industry reports,
        and precious metals analysis from across Africa and beyond.
    </p>

</section>

<section class="stats-bar fade-section">
    <div class="stat">
        <h3>120+</h3>
        <p>Market Insights</p>
    </div>

    <div class="stat">
        <h3>45+</h3>
        <p>Expert Articles</p>
    </div>

    <div class="stat">
        <h3>Daily</h3>
        <p>Gold Updates</p>
    </div>

    <div class="stat">
        <h3>Global</h3>
        <p>Coverage</p>
    </div>
</section>

<section class="ticker">
    <div class="ticker-content">
        Gold Market Intelligence • Investment Insights • Precious Metals • Market Trends • Wealth Preservation • Gold Market Africa •
    </div>
</section>

<!-- FEATURED COLLECTION -->

<!-- FEATURED COLLECTION -->

<section>

<h2 class="section-title">
    Signature Collection
</h2>

<p class="section-subtitle">
    A curated showcase of exceptional gold products and precious metal pieces.
</p>

<div class="cards">

    <% if(products.length === 0){ %>

        <div class="card">
            <h3>No Products Yet</h3>
            <p>Products will appear here when added by admin.</p>
        </div>

    <% } else { %>

        <% products.slice(0,6).forEach(product => { %>

            <div class="card">

                <% if(product.image && product.image !== "") { %>

                    <img
                        src="<%= product.image %>"
                        alt="<%= product.title %>"
                    >

                <% } else { %>

                    <div style="
                        height:200px;
                        display:flex;
                        align-items:center;
                        justify-content:center;
                        background:#101820;
                        color:#777;
                        border-radius:8px;
                    ">
                        No Image Available
                    </div>

                <% } %>

                <h3>
                    <%= product.title %>
                </h3>

                <p>
                    <%= product.description.substring(0,100) %>...
                </p>

                <br>

                <a
                    href="/products/view/<%= product.id %>"
                    class="btn"
                >
                    Discover More
                </a>

            </div>

        <% }) %>

    <% } %>

</div>

</section>

<!-- LATEST ARTICLES -->

<section class="latest-preview fade-section">

<h2 class="section-title">
    Latest Articles
</h2>

<p class="section-subtitle">
    Expert insights, market analysis and precious metals updates.
</p>

<div class="cards">

    <% if(posts && posts.length > 0){ %>

        <% posts.slice(0,3).forEach(post => { %>

            <div class="card">

                <h3>
                    <%= post.title %>
                </h3>

                <p>
                    <%= post.content.substring(0,120) %>...
                </p>

                <br>

                <a
                    href="/blog/<%= post.id %>"
                    class="btn"
                >
                    Read Article
                </a>

            </div>

        <% }) %>

    <% } else { %>

        <div class="card">
            <h3>Gold Market Trends</h3>
            <p>
                Expert analysis and commentary on the global gold market.
            </p>
        </div>

        <div class="card">
            <h3>Investment Insights</h3>
            <p>
                Learn about wealth preservation and precious metals.
            </p>
        </div>

        <div class="card">
            <h3>Industry Updates</h3>
            <p>
                Stay informed with the latest developments in the sector.
            </p>
        </div>

    <% } %>

</div>

</section>

<section class="featured-topics fade-section">

    <h2 class="section-title">
        Explore Topics
    </h2>

    <div class="cards">

        <div class="card">
            <h3>Gold Investment</h3>
            <p>Strategies, guides and market opportunities.</p>
        </div>

        <div class="card">
            <h3>Mining Industry</h3>
            <p>Updates from African and global mining sectors.</p>
        </div>

        <div class="card">
            <h3>Market Analysis</h3>
            <p>Price trends and expert commentary.</p>
        </div>

        <div class="card">
            <h3>Precious Metals</h3>
            <p>Silver, platinum and emerging opportunities.</p>
        </div>

    </div>

</section>

<!-- ABOUT -->

<section class="about fade-section">

    <h2 class="section-title">
        About Gold Market Africa
    </h2>

    <p>
        Gold Market Africa is dedicated to showcasing premium gold
        products and precious metal collections with a commitment to
        quality, authenticity and professional presentation.
        Our mission is to provide a trusted platform where excellence,
        craftsmanship and value are always at the forefront.
    </p>

</section>

<!-- WHY CHOOSE US -->

<section class="why-us fade-section">

    <h2 class="section-title">
        Why Choose Us
    </h2>

    <div class="cards">

        <div class="card">
            <h3>Authenticity</h3>
            <p>
                Every showcased product is presented with quality 
                and professional standards. We emphasize accurate product 
                information, clear presentation, and trustworthy business 
                practices to help connect serious buyers and sellers. 
                By promoting transparency and reliability, Gold Market Africa 
                supports a marketplace where confidence and long-term business 
                relationships can grow.
            </p>
        </div>

        <div class="card">
            <h3>Luxury Presentation</h3>
            <p>
                A premium experience designed around elegance, trust, and value. 
                From refined product displays to a seamless browsing experience, 
                every aspect of our platform is crafted to reflect 
                the prestige of the gold industry. We combine sophisticated 
                design with professional standards to ensure that buyers and sellers 
                engage in an environment that inspires confidence, credibility, and 
                excellence.
            </p>
        </div>

        <div class="card">
            <h3>Professional Service</h3>
            <p>
                Dedicated support and information for every inquiry. 
                Our team is committed to providing timely assistance, 
                clear communication, and reliable guidance throughout your experience 
                on the platform. Whether you are exploring investment opportunities, 
                sourcing products, or seeking market insights, we strive to deliver a high 
                standard of service that ensures confidence, convenience, 
                and satisfaction at every step.
            </p>
        </div>

    </div>

</section>

<!-- INSIGHTS -->

<section class="insights fade-section">

    <h2 class="section-title">
        Latest Insights
    </h2>

    <div class="cards">

        <div class="insight-card">
            <h3>Gold Market Trends</h3>
            <p>
                Understanding the movements shaping the precious
                metals industry.
            </p>
        </div>

        <div class="insight-card">
            <h3>Investment Knowledge</h3>
            <p>
                Explore educational content about gold and
                wealth preservation.
            </p>
        </div>

        <div class="insight-card">
            <h3>Industry Updates</h3>
            <p>
                Stay informed with the latest developments in
                precious metals.
            </p>
        </div>

    </div>

</section>

<section class="newsletter fade-section">

    <h2>Stay Updated</h2>

    <p>
        Get the latest gold market insights and industry updates.
    </p>

    <a href="/contact" class="btn">
        Contact Us
    </a>

</section>

<footer>

    <div class="footer-content">

        <h3 style="color:#C8A24A;">
            Gold Market Africa
        </h3>

        <p>
            Premium Gold Products • Precious Metals • Luxury Collections
        </p>

        <p>
            © 2026 Gold Market Africa. All Rights Reserved.
        </p>

    </div>

</footer>

<script>
const text = "Rare. Valuable. Timeless.";
let i = 0;

function typeEffect() {
    if (i < text.length) {
        document.getElementById("typed-text").innerHTML += text.charAt(i);
        i++;
        setTimeout(typeEffect, 90);
    }
}

window.onload = () => {
    typeEffect();

    const sections = document.querySelectorAll(".fade-section");

    function revealSections() {
        sections.forEach(section => {
            const top = section.getBoundingClientRect().top;

            if (top < window.innerHeight - 100) {
                section.classList.add("show");
            }
        });
    }

    revealSections();

    window.addEventListener("scroll", revealSections);
};
</script>

</body>
</html>