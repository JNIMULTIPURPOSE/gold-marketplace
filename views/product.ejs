<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= product?.title || "Product" %> - Gold Market Africa</title>

    <link rel="stylesheet" href="/css/style.css">

    <style>
        body {
            margin: 0;
            font-family: "Segoe UI", sans-serif;
            background: #0B0F14;
            color: #E6E6E6;
        }

        .container {
            max-width: 1000px;
            margin: auto;
            padding: 40px 20px;
        }

        .back {
            display: inline-block;
            margin-bottom: 20px;
            color: #C8A24A;
            text-decoration: none;
        }

        .product-card {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            background: #101C33;
            padding: 30px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.06);
        }

        .product-image img {
            width: 100%;
            border-radius: 10px;
        }

        .placeholder {
            height: 300px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #101820;
            color: #777;
            border-radius: 10px;
        }

        h1 {
            color: #C8A24A;
            margin-bottom: 10px;
        }

        .price {
            font-size: 22px;
            margin: 15px 0;
            color: #fff;
        }

        p {
            line-height: 1.8;
            color: #AAB3C5;
        }

        .btn {
            display: inline-block;
            margin-top: 20px;
            padding: 12px 20px;
            background: #25D366;
            color: #fff;
            border-radius: 6px;
            text-decoration: none;
            font-weight: bold;
        }

        @media (max-width: 768px) {
            .product-card {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>

<div class="container">

    <a href="/" class="back">← Back to Home</a>

    <div class="product-card">

        <!-- IMAGE -->
        <div class="product-image">

            <% if(product && product.image){ %>

                <% if(product.image !== "") { %>

                    <img src="/uploads/<%= product.image %>" alt="<%= product.title %>">

                <% } else { %>

                    <div class="placeholder">
                        No Image Available
                    </div>

                <% } %>

            <% } else { %>

                <div class="placeholder">
                    No Image Available
                </div>

            <% } %>

        </div>

        <!-- INFO -->
        <div>

            <h1><%= product?.title || "Untitled Product" %></h1>

            <div class="price">
                💰 Price: <%= product?.price || "N/A" %>
            </div>

            <p>
                <%= product?.description || "No description available." %>
            </p>

            <a
                class="btn"
                href="https://wa.me/254700000000?text=Hello%2C%20I%20want%20to%20buy%20<%= encodeURIComponent(product?.title || '') %>"
                target="_blank"
            >
                Buy via WhatsApp
            </a>

        </div>

    </div>

</div>

</body>
</html>