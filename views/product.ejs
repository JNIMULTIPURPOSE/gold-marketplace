<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= product?.title || "Product" %> - Gold Market Africa</title>

    <link rel="stylesheet" href="/css/style.css">

    <style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', sans-serif;
    background: #0B0F14;
    color: #E6E6E6;
    line-height: 1.6;
}

/* CENTERING SYSTEM (THIS IS THE FIX) */
.container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 60px 20px;
}

/* BACK LINK */
.back {
    display: inline-block;
    margin-bottom: 25px;
    color: #C8A24A;
    text-decoration: none;
    font-weight: 500;
}

/* PRODUCT LAYOUT */
.product-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    background: rgba(16, 28, 51, 0.6);
    backdrop-filter: blur(10px);
    padding: 40px;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.08);
    align-items: center;
}

/* IMAGE */
.product-image img {
    width: 100%;
    border-radius: 14px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.4);
}

.placeholder {
    height: 350px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #101820;
    border-radius: 14px;
    color: #777;
}

/* TYPOGRAPHY */
h1 {
    font-size: 38px;
    color: #C8A24A;
    margin-bottom: 15px;
}

.price {
    font-size: 22px;
    font-weight: 600;
    margin: 20px 0;
    color: #ffffff;
}

p {
    color: #AAB3C5;
    font-size: 16px;
    line-height: 1.8;
}

/* BUTTON */
.btn {
    display: inline-block;
    margin-top: 25px;
    padding: 14px 22px;
    background: linear-gradient(135deg, #25D366, #1ebe57);
    color: white;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 600;
    transition: 0.2s ease;
}

.btn:hover {
    transform: translateY(-2px);
}

/* RESPONSIVE */
@media (max-width: 768px) {
    .product-card {
        grid-template-columns: 1fr;
        padding: 25px;
    }

    h1 {
        font-size: 28px;
    }
}
</style>
</head>

<body>

<div class="container">

    <a href="/" class="back">Home</a>

    <div class="product-card">

        <!-- IMAGE -->
        <div class="product-image">

            <% if(product && product.image){ %>

                <% if(product.image !== "") { %>

                    <img src="/uploads/<%= product.image %>" alt="<%= product.title %>">

                <% } else { %>

                    <div class="placeholder">
                        No Image Available
                    </div>

                <% } %>

            <% } else { %>

                <div class="placeholder">
                    No Image Available
                </div>

            <% } %>

        </div>

        <!-- INFO -->
        <div>

            <h1><%= product?.title || "Untitled Product" %></h1>

            <div class="price">
                💰 Price: <%= product?.price || "N/A" %>
            </div>

            <p>
                <%= product?.description || "No description available." %>
            </p>

            <a
                class="btn"
                href="https://wa.me/254700000000?text=Hello%2C%20I%20want%20to%20buy%20<%= encodeURIComponent(product?.title || '') %>"
                target="_blank"
            >
                Contact via WhatsApp
            </a>

        </div>

    </div>

</div>

</body>
</html>