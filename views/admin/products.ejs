<!DOCTYPE html>
<html>
<head>
    <title>Product Management</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;

            /* Softer dark base (NOT pure black) */
            background: #0B1220;

            color: #E6E6E6;
        }

        /* HEADER */
        .header {
            background: #0F1A2B; /* navy layer */
            padding: 20px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .header h2 {
            color: #C8A24A;
            margin: 0;
            font-weight: 400;
            letter-spacing: 1px;
        }

        .header a {
            color: #aaa;
            text-decoration: none;
            margin-left: 15px;
            font-size: 14px;
        }

        .header a:hover {
            color: #C8A24A;
        }

        /* WRAPPER */
        .container {
            padding: 30px;
        }

        /* TITLE AREA */
        h1 {
            color: #C8A24A;
            font-weight: 400;
            margin-bottom: 10px;
        }

        .subtitle {
            color: #8A93A3;
            margin-bottom: 25px;
        }

        /* ADD BUTTON */
        .add-btn {
            display: inline-block;
            background: #C8A24A;
            color: #0B1220;
            padding: 10px 14px;
            border-radius: 5px;
            text-decoration: none;
            font-weight: bold;
            margin-bottom: 20px;
        }

        .add-btn:hover {
            opacity: 0.9;
        }

        /* PRODUCT GRID */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 20px;
        }

        /* CARD */
        .card {
            background: #101C33; /* navy card layer */
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 10px;
            padding: 15px;
            transition: 0.2s;
        }

        .card:hover {
            transform: translateY(-3px);
            border-color: rgba(200,162,74,0.4);
        }

        .card img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            border-radius: 8px;
            margin-bottom: 10px;
        }

        .card h3 {
            color: #C8A24A;
            margin: 10px 0 5px;
        }

        .card p {
            color: #AAB3C5;
            font-size: 14px;
            margin: 5px 0;
        }

        /* ACTIONS */
        .actions {
            margin-top: 10px;
        }

        .actions a {
            font-size: 13px;
            margin-right: 10px;
            text-decoration: none;
            color: #aaa;
        }

        .actions a:hover {
            color: #C8A24A;
        }

        /* EMPTY STATE */
        .empty {
            color: #777;
            padding: 20px;
        }
    </style>
</head>
<body>

<div class="header">
    <h2>Product Management</h2>

    <div>
        <a href="/admin/dashboard">Dashboard</a>
        <a href="/admin/logout">Logout</a>
    </div>
</div>

<div class="container">

    <h1>Gold Products</h1>
    <div class="subtitle">Manage your investment listings</div>

    <a class="add-btn" href="/products/new">+ Add Product</a>

    <% if (products.length === 0) { %>

        <div class="empty">No products available.</div>

    <% } else { %>

        <div class="grid">

            <% products.forEach(product => { %>

                <div class="card">

                    <% if(product.image){ %>
                        <img src="/uploads/<%= product.image %>" />
                    <% } %>

                    <h3><%= product.title %></h3>

                    <p><strong>Price:</strong> <%= product.price %></p>

                    <p><%= product.description %></p>

                    <div class="actions">
                        <a href="/products/edit/<%= product.id %>">Edit</a>
                        <a href="/products/delete/<%= product.id %>"
                           onclick="return confirm('Delete this product?')">
                           Delete
                        </a>
                    </div>

                </div>

            <% }) %>

        </div>

    <% } %>

</div>

</body>
</html>