<!DOCTYPE html>
<html>
<head>
    <title>Edit Product</title>
</head>
<body>

<h1>Edit Product</h1>

<form method="POST">

    <label>Title</label>
    <br>
    <input
        type="text"
        name="title"
        value="<%= product.title %>"
        required
    >

    <br><br>

    <label>Price</label>
    <br>
    <input
        type="text"
        name="price"
        value="<%= product.price %>"
        required
    >

    <br><br>

    <label>Description</label>
    <br>
    <textarea
        name="description"
        rows="5"
        cols="50"
    ><%= product.description %></textarea>

    <br><br>

    <button type="submit">
        Update Product
    </button>

</form>

</body>
</html>