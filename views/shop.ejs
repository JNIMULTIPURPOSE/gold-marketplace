<!DOCTYPE html>
<html>
<head>
    <title>Gold Market Africa | Signature Collection</title>

    <link rel="stylesheet" href="/css/style.css">

    <style>

        .collection-hero {
            text-align: center;
            padding: 80px 20px;
        }

        .collection-hero h1 {
            color: #C8A24A;
            font-size: 48px;
            margin-bottom: 15px;
            font-weight: 400;
            letter-spacing: 1px;
        }

        .collection-hero p {
            max-width: 700px;
            margin: auto;
            color: #AAB3C5;
            line-height: 1.8;
        }

        .collection-grid {
            max-width: 1400px;
            margin: auto;
            padding: 20px 40px 80px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
        }

        .collection-card {
            background: #101C33;
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 12px;
            overflow: hidden;
            transition: 0.3s;
        }

        .collection-card:hover {
            transform: translateY(-5px);
            border-color: rgba(200,162,74,0.4);
        }

        .collection-card img {
            width: 100%;
            height: 260px;
            object-fit: contain;
            background: #0B1220;
            padding: 10px;
            transition: 0.4s;
        }

        .collection-card:hover img {
            transform: scale(1.03);
        }

        .card-content {
            padding: 20px;
        }

        .card-title {
            color: #C8A24A;
            font-size: 20px;
            margin-bottom: 12px;
        }

        .card-description {
            color: #AAB3C5;
            line-height: 1.7;
            font-size: 14px;
            margin-bottom: 20px;
        }

        .view-btn {
            display: inline-block;
            padding: 10px 18px;
            background: #C8A24A;
            color: #0B1220;
            text-decoration: none;
            border-radius: 6px;
            font-weight: 600;
        }

        .view-btn:hover {
            opacity: .9;
        }

    </style>
</head>

<body>

<header>

    <h2>Gold Market Africa</h2>

    <nav>
    <a href="/">Home</a>
    <a href="/shop">Collection</a>
    <a href="/about">About</a>
    <a href="/blog">Insights</a>
    <a href="/contact">Contact</a>
</nav>

</header>

<section class="collection-hero">

    <h1>Signature Collection</h1>

    <p>
        Explore a curated showcase of premium gold products,
        precious metal pieces, and distinguished collections
        presented with elegance and authenticity.
    </p>

</section>

<section class="collection-grid">

    <% if(products.length === 0){ %>

        <div class="collection-card">

            <div class="card-content">

                <h3 class="card-title">
                    Collection Coming Soon
                </h3>

                <p class="card-description">
                    Products added by administrators will appear here.
                </p>

            </div>

        </div>

    <% } else { %>

        <% products.forEach(product => { %>

            <div class="collection-card">

                <% if(product.image){ %>

                    <% if(product.image && product.image !== "") { %>

    <img
        src="/uploads/<%= product.image %>"
        alt="<%= product.title %>"
    >

<% } else { %>

    <div style="
        height: 200px;
        display:flex;
        align-items:center;
        justify-content:center;
        background:#101820;
        color:#777;
        border-radius:8px;
    ">
        No Image Available
    </div>

<% } %>

                <% } %>

                <div class="card-content">

                    <div class="card-title">
                        <%= product.title %>
                    </div>

                    <div class="card-description">
                        <%= product.description.substring(0, 120) %>...
                    </div>

                    <a
                        href="/products/view/<%= product.id %>"
                        class="view-btn"
                    >
                        Discover More
                    </a>

                </div>

            </div>

        <% }) %>

    <% } %>

</section>

<footer>
    © 2026 Gold Market Africa. All Rights Reserved.
</footer>

</body>
</html>