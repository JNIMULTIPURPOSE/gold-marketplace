<!DOCTYPE html>
<html>
<head>
    <title>Contact | Gold Market Africa</title>
    <meta name="description" content="Contact Gold Market Africa for inquiries regarding our collections and industry information.">
    <link rel="stylesheet" href="/css/style.css">

    <style>

        .contact-wrapper {
            max-width: 900px;
            margin: 80px auto;
            padding: 20px;
            text-align: center;
        }

        .contact-wrapper h1 {
            color: #C8A24A;
            font-size: 42px;
            margin-bottom: 10px;
            font-weight: 400;
        }

        .contact-wrapper p {
            color: #AAB3C5;
            line-height: 1.8;
            margin-bottom: 40px;
        }

        .contact-card {
            background: #101C33;
            border: 1px solid rgba(255,255,255,0.06);
            padding: 30px;
            border-radius: 12px;
        }

        .info {
            margin-bottom: 25px;
            color: #AAB3C5;
        }

        .info strong {
            color: #C8A24A;
        }

        .btn-whatsapp {
            display: inline-block;
            padding: 14px 22px;
            background: #C8A24A;
            color: #0B1220;
            text-decoration: none;
            border-radius: 6px;
            font-weight: bold;
            margin-top: 20px;
        }

        .btn-whatsapp:hover {
            opacity: 0.9;
        }

    </style>

</head>
<body>

<header>

    <h2>Gold Market Africa</h2>

    <nav>
        <a href="/">Home</a>
        <a href="/shop">Collection</a>
        <a href="/about">About</a>
        <a href="/blog">Insights</a>
        <a href="/contact">Contact</a>
    </nav>

</header>

<div class="contact-wrapper">

    <h1>Contact Us</h1>

    <p>
        For inquiries about our gold collections and premium
        showcase products, reach out through the channels below.
    </p>

    <div class="contact-card">

        <div class="info">
            <strong>WhatsApp:</strong> +254 707 209 808
        </div>

        <div class="info">
            <strong>Email:</strong> info@goldmarketafrica.com
        </div>

        <div class="info">
            <strong>Response Time:</strong> Within 24 hours
        </div>

        <a
            class="btn-whatsapp"
            target="_blank"
            href="https://wa.me/254707209808"
        >
            Message on WhatsApp
        </a>

    </div>

</div>

<footer>
    © 2026 Gold Market Africa. All Rights Reserved.
</footer>

</body>
</html>