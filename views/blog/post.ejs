<!DOCTYPE html>
<html>
<head>
    <title><%= post.title %> | Gold Market Africa</title>
    <meta name="description" content="<%= post.title %>">
    <link rel="stylesheet" href="/css/style.css">

    <style>

        .article-container {
            max-width: 800px;
            margin: 80px auto;
            padding: 20px;
        }

        .back-link {
            display: inline-block;
            margin-bottom: 30px;
            color: #AAB3C5;
            text-decoration: none;
        }

        .back-link:hover {
            color: #C8A24A;
        }

        h1 {
            color: #C8A24A;
            font-size: 42px;
            font-weight: 400;
            margin-bottom: 20px;
            line-height: 1.3;
        }

        .content {
            color: #AAB3C5;
            font-size: 17px;
            line-height: 2;
            white-space: pre-line;
        }

        .meta {
            margin-bottom: 30px;
            color: #777;
            font-size: 13px;
        }

    </style>

</head>
<body>

<header>

    <h2>Gold Market Africa</h2>

    <nav>
        <a href="/">Home</a>
        <a href="/shop">Collection</a>
        <a href="/about">About</a>
        <a href="/blog">Insights</a>
        <a href="/contact">Contact</a>
    </nav>

</header>

<div class="article-container">

    <a href="/blog" class="back-link">
        ← Back to Insights
    </a>

    <div class="meta">
        Published Article
    </div>

    <h1>
        <%= post.title %>
    </h1>

    <div class="content">
        <%= post.content %>
    </div>

</div>

<footer>
    © 2026 Gold Market Africa. All Rights Reserved.
</footer>

</body>
</html>