<!DOCTYPE html>
<html>
<head>
    <title><%= product.title %> | Gold Market Africa</title>

    <link rel="stylesheet" href="/css/style.css">

    <style>

        .product-wrapper{
    max-width:1300px;
    margin:60px auto;
    padding:20px;
    display:grid;
    grid-template-columns:1.1fr 1fr;
    gap:60px;
    align-items:center;
}

.product-image{
    background:linear-gradient(
        145deg,
        #101C33,
        #162748
    );
    border-radius:16px;
    padding:30px;
    border:1px solid rgba(200,162,74,.15);
}

.product-image img{
    width:100%;
    height:550px;
    object-fit:contain;
}

.product-info{
    background:#101820;
    padding:40px;
    border-radius:16px;
    border:1px solid rgba(255,255,255,.05);
}

.product-info h1{
    color:#C8A24A;
    font-size:48px;
    margin-top:0;
    margin-bottom:20px;
    font-weight:300;
    line-height:1.2;
}

.product-info p{
    color:#AAB3C5;
    line-height:2;
    font-size:16px;
}

.section-title{
    color:#C8A24A;
    margin-top:35px;
    margin-bottom:12px;
    font-size:20px;
    font-weight:500;
    letter-spacing:.5px;
}

.collection-badge{
    display:inline-block;
    background:rgba(200,162,74,.12);
    color:#C8A24A;
    border:1px solid rgba(200,162,74,.25);
    padding:8px 14px;
    border-radius:30px;
    margin-bottom:25px;
    font-size:13px;
    letter-spacing:1px;
    text-transform:uppercase;
}

.back-link{
    display:inline-block;
    margin-bottom:25px;
    color:#8FA4C5;
    text-decoration:none;
}

.back-link:hover{
    color:#C8A24A;
}

.inquiry-btn{
    display:inline-block;
    margin-top:35px;
    background:#C8A24A;
    color:#0B1220;
    text-decoration:none;
    padding:14px 28px;
    border-radius:8px;
    font-weight:600;
}

.inquiry-btn:hover{
    transform:translateY(-2px);
}

@media(max-width:900px){

    .product-wrapper{
        grid-template-columns:1fr;
    }

    .product-image img{
        height:350px;
    }

    .product-info h1{
        font-size:34px;
    }

}

    </style>

</head>
<body>

<header>

    <h2>Gold Market Africa</h2>

    <nav>
    <a href="/">Home</a>
    <a href="/shop">Collection</a>
    <a href="/about">About</a>
    <a href="/blog">Insights</a>
    <a href="/contact">Contact</a>
</nav>

</header>

<div class="product-wrapper">

    <div class="product-image">

        <% if(product.image){ %>

            <img
                src="/uploads/<%= product.image %>"
                alt="<%= product.title %>"
            >

        <% } %>

    </div>

    <div class="product-info">

        <a href="/shop" class="back-link">
    ← Back to Collection
</a>

<div class="collection-badge">
    Signature Collection
</div>

<h1>
    <%= product.title %>
</h1>

        <h3 class="section-title">
            Overview
        </h3>

        <p>
            <%= product.description %>
        </p>

        <h3 class="section-title">
    Collection Information
</h3>

<p>
    Featured within the Gold Market Africa collection,
    this piece represents the craftsmanship, rarity and
    enduring value associated with precious metals.
    Presented exclusively as part of our curated showcase.
</p>

        <a
            class="inquiry-btn"
            target="_blank"
            href="https://wa.me/254707209808?text=Hello,%20I%20would%20like%20more%20information%20about%20<%= product.title %>"
        >
            Request Information
        </a>

    </div>

</div>

<footer>
    © 2026 Gold Market Africa. All Rights Reserved.
</footer>

</body>
</html>